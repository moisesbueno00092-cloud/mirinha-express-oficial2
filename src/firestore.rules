
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Regra principal: Um utilizador só pode aceder aos seus próprios documentos
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Permite que um utilizador crie/leia o seu próprio perfil.
    // É necessário para que as regras de subcoleção funcionem.
    match /users/{userId} {
      allow read, create: if isOwner(userId);
      // Impede a modificação do email após a criação para segurança.
      allow update: if isOwner(userId) && request.resource.data.email == resource.data.email;
    }
    
    // Permite que um utilizador leia e escreva nas suas próprias subcoleções.
    // A condição `exists` garante que a leitura da coleção só é permitida se o documento pai (perfil) existir.
    match /users/{userId}/{collection}/{docId} {
       allow read, write: if isOwner(userId) && exists(/databases/$(database)/documents/users/$(userId));
    }

    // Itens da bomboniere podem ser lidos e escritos por qualquer utilizador autenticado
    match /bomboniere_items/{itemId} {
      allow read, write: if request.auth != null;
    }

    // Coleções de administração (qualquer utilizador autenticado pode ler e escrever)
    match /fornecedores/{fornecedorId} {
        allow read, write: if request.auth != null;
    }

    match /contas_a_pagar/{contaId} {
        allow read, write: if request.auth != null;
    }

    match /entradas_mercadorias/{entradaId} {
        allow read, write: if request.auth != null;
    }

    // Permite acesso total à coleção de funcionários e suas subcoleções
    match /funcionarios/{funcionarioId}/{document=**} {
        allow read, write: if request.auth != null;
    }
  }
}

    