rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Regra explícita para o documento do utilizador e suas subcoleções
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Permissão explícita para listar e aceder a itens de pedido
      match /order_items/{orderId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      // Permissão explícita para listar e aceder a relatórios diários
      match /daily_reports/{reportId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    match /bomboniere_items/{itemId} {
      allow read, write: if request.auth != null;
    }
    
    match /fornecedores/{fornecedorId} {
      allow read, write: if request.auth != null;
    }
    
    match /contas_a_pagar/{contaId} {
      allow read, write: if request.auth != null;
    }
    
    match /entradas_mercadorias/{entradaId} {
      allow read, write: if request.auth != null;
    }
    
    // Regra explícita para funcionários e suas subcoleções
    match /funcionarios/{funcionarioId} {
       allow read, write: if request.auth != null;
       
       match /lancamentos/{lancamentoId} {
         allow read, write: if request.auth != null;
       }
       
       match /holerites/{holeriteId} {
         allow read, write: if request.auth != null;
       }
    }
  }
}
