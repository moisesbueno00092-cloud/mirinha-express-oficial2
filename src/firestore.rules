rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Regra principal: Um utilizador autenticado pode ler e escrever todos os documentos
    // e subcoleções (como order_items, daily_reports, etc.) dentro do seu próprio caminho.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Itens da bomboniere podem ser lidos e escritos por qualquer utilizador autenticado.
    match /bomboniere_items/{itemId} {
      allow read, write: if request.auth != null;
    }

    // As coleções de administração podem ser lidas e escritas por qualquer utilizador autenticado.
    match /fornecedores/{fornecedorId} {
        allow read, write: if request.auth != null;
    }

    match /contas_a_pagar/{contaId} {
        allow read, write: if request.auth != null;
    }

    match /entradas_mercadorias/{entradaId} {
        allow read, write: if request.auth != null;
    }

    // A coleção de funcionários e todas as suas subcoleções (lancamentos, holerites)
    // podem ser lidas e escritas por qualquer utilizador autenticado.
    match /funcionarios/{funcionarioId}/{document=**} {
        allow read, write: if request.auth != null;
    }
  }
}
