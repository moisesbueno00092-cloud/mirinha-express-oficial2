
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Permite que um utilizador aceda a todos os documentos e subcoleções
    // dentro do seu próprio diretório de utilizador.
    match /users/{userId}/{documents=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Regras para coleções partilhadas (acessíveis por qualquer utilizador autenticado)
    match /bomboniere_items/{itemId} {
      allow read, write: if request.auth != null;
    }
    
    match /fornecedores/{fornecedorId} {
      allow read, write: if request.auth != null;
    }
    
    match /contas_a_pagar/{contaId} {
      allow read, write: if request.auth != null;
    }
    
    match /entradas_mercadorias/{entradaId} {
      allow read, write: if request.auth != null;
    }
    
    match /funcionarios/{funcionarioId}/{documents=**} {
       allow read, write: if request.auth != null;
    }
  }
}
