
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "type": "object",
      "description": "Represents a user's profile information.",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        }
      },
      "required": ["email"]
    },
    "OrderItem": {
      "title": "Order Item",
      "type": "object",
      "description": "Represents an individual item ordered at the restaurant.",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user who created the order item."
        },
        "name": {
          "type": "string",
          "description": "The name of the item ordered."
        },
        "price": {
          "type": "number",
          "description": "The price of the item."
        },
        "group": {
          "type": "string",
          "description": "The group the item belongs to."
        },
        "quantity": {
          "type": "number",
          "description": "The quantity of the item ordered."
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "The date and time the item was ordered."
        },
        "total": {
          "type": "number"
        }
      },
      "required": ["userId", "name", "price", "group", "quantity", "timestamp", "total"]
    },
    "FavoriteClient": {
      "title": "Favorite Client",
      "type": "object",
      "description": "Represents a favorite client with a saved command.",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user who saved this favorite client."
        },
        "name": {
          "type": "string",
          "description": "The name of the favorite client."
        },
        "command": {
          "type": "string",
          "description": "The saved command for the client's usual order."
        }
      },
      "required": ["userId", "name", "command"]
    },
    "Expense": {
      "title": "Expense",
      "type": "object",
      "description": "Represents a business expense.",
      "properties": {
        "userId": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "amount": {
          "type": "number"
        },
        "category": {
          "type": "string"
        },
        "date": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["userId", "description", "amount", "category", "date"]
    },
    "Payable": {
      "title": "Payable",
      "type": "object",
      "description": "Represents a bill or payable item.",
      "properties": {
        "userId": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "amount": {
          "type": "number"
        },
        "dueDate": {
          "type": "string",
          "format": "date-time"
        },
        "isPaid": {
          "type": "boolean"
        }
      },
      "required": ["userId", "description", "amount", "dueDate", "isPaid"]
    },
    "Employee": {
      "title": "Employee",
      "type": "object",
      "description": "Represents an employee.",
      "properties": {
        "userId": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "role": {
          "type": "string"
        },
        "salary": {
          "type": "number"
        }
      },
      "required": ["userId", "name", "role", "salary"]
    },
    "EmployeeAdvance": {
      "title": "Employee Advance",
      "type": "object",
      "description": "Represents a salary advance (vale) for an employee.",
      "properties": {
        "userId": {
          "type": "string"
        },
        "employeeId": {
          "type": "string"
        },
        "employeeName": {
            "type": "string"
        },
        "amount": {
          "type": "number"
        },
        "date": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["userId", "employeeId", "employeeName", "amount", "date"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": {
            "$ref": "#/backend/entities/UserProfile"
          },
          "description": "Stores user profile data."
        }
      },
      {
        "path": "/order_items/{orderItemId}",
        "definition": {
          "entityName": "OrderItem",
          "schema": {
            "$ref": "#/backend/entities/OrderItem"
          },
          "description": "Collection of all order items across all users."
        }
      },
      {
        "path": "/favorite_clients/{clientId}",
        "definition": {
          "entityName": "FavoriteClient",
          "schema": {
            "$ref": "#/backend/entities/FavoriteClient"
          },
          "description": "Collection of all favorite clients across all users."
        }
      },
      {
        "path": "/bomboniere_items/{itemId}",
        "definition": {
          "entityName": "BomboniereItem",
          "schema": {
            "$ref": "#/backend/entities/BomboniereItem"
          },
          "description": "Shared list of bomboniere items."
        }
      },
      {
        "path": "/daily_reports/{reportId}",
        "definition": {
          "entityName": "DailyReport",
          "schema": {
            "$ref": "#/backend/entities/DailyReport"
          },
          "description": "Daily sales reports."
        }
      },
      {
        "path": "/expenses/{expenseId}",
        "definition": {
          "entityName": "Expense",
          "schema": {
            "$ref": "#/backend/entities/Expense"
          },
          "description": "Collection of all business expenses."
        }
      },
      {
        "path": "/payables/{payableId}",
        "definition": {
          "entityName": "Payable",
          "schema": {
            "$ref": "#/backend/entities/Payable"
          },
          "description": "Collection of all bills to be paid."
        }
      },
      {
        "path": "/employees/{employeeId}",
        "definition": {
          "entityName": "Employee",
          "schema": {
            "$ref": "#/backend/entities/Employee"
          },
          "description": "Collection of all employees."
        }
      },
      {
        "path": "/employees/{employeeId}/advances/{advanceId}",
        "definition": {
          "entityName": "EmployeeAdvance",
          "schema": {
            "$ref": "#/backend/entities/EmployeeAdvance"
          },
          "description": "Sub-collection of salary advances for a specific employee."
        }
      }
    ]
  }
}
