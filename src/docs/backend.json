
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "type": "object",
      "description": "Represents a user's profile information.",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        }
      },
      "required": ["email"]
    },
    "OrderItem": {
      "title": "Order Item",
      "type": "object",
      "description": "Represents an individual item ordered at the restaurant.",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user who created the order item."
        },
        "name": {
          "type": "string",
          "description": "The name of the item ordered."
        },
        "price": {
          "type": "number",
          "description": "The price of the item."
        },
        "group": {
          "type": "string",
          "description": "The group the item belongs to."
        },
        "quantity": {
          "type": "number",
          "description": "The quantity of the item ordered."
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "The date and time the item was ordered."
        },
        "total": {
          "type": "number"
        }
      },
      "required": ["userId", "name", "price", "group", "quantity", "timestamp", "total"]
    },
    "FavoriteClient": {
      "title": "Favorite Client",
      "type": "object",
      "description": "Represents a favorite client with a saved command.",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user who saved this favorite client."
        },
        "name": {
          "type": "string",
          "description": "The name of the favorite client."
        },
        "command": {
          "type": "string",
          "description": "The saved command for the client's usual order."
        }
      },
      "required": ["userId", "name", "command"]
    },
    "BomboniereItem": {
      "title": "Bomboniere Item",
      "description": "Represents a bomboniere item with stock control.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "estoque": { "type": "number" }
      },
      "required": ["name", "price", "estoque"]
    },
    "DailyReport": {
      "title": "Daily Report",
      "description": "Represents a consolidated daily sales report.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "reportDate": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" },
        "totalGeral": { "type": "number" },
        "totalAVista": { "type": "number" },
        "totalFiado": { "type": "number" },
        "totalVendasSalao": { "type": "number" },
        "totalVendasRua": { "type": "number" },
        "totalFiadoSalao": { "type": "number" },
        "totalFiadoRua": { "type": "number" },
        "totalKg": { "type": "number" },
        "totalTaxas": { "type": "number" },
        "totalBomboniereSalao": { "type": "number" },
        "totalBomboniereRua": { "type": "number" },
        "totalItens": { "type": "number" },
        "totalPedidos": { "type": "number" },
        "totalEntregas": { "type": "number" },
        "totalItensRua": { "type": "number" },
        "contagemTotal": { "type": "object" },
        "contagemRua": { "type": "object" },
        "items": { "type": "array", "items": { "$ref": "#/backend/entities/OrderItem" }}
      },
      "required": [
        "userId", "reportDate", "createdAt", "totalGeral", "totalAVista", "totalFiado", "items"
      ]
    },
     "Fornecedor": {
      "title": "Fornecedor",
      "description": "Representa um fornecedor de mercadorias.",
      "type": "object",
      "properties": {
        "nome": { "type": "string" }
      },
      "required": ["nome"]
    },
    "Produto": {
      "title": "Produto",
      "description": "Representa um produto para controle de estoque e compras.",
      "type": "object",
      "properties": {
        "nome": { "type": "string" },
        "unidade": { "type": "string", "enum": ["un", "kg", "lt"] },
        "estoqueMinimo": { "type": "number" },
        "estoqueAtual": { "type": "number" }
      },
      "required": ["nome", "unidade", "estoqueAtual"]
    },
    "EntradaMercadoria": {
      "title": "Entrada de Mercadoria",
      "description": "Registra a entrada de uma mercadoria, vinculando produto e fornecedor.",
      "type": "object",
      "properties": {
        "produtoId": { "type": "string" },
        "fornecedorId": { "type": "string" },
        "data": { "type": "string", "format": "date-time" },
        "quantidade": { "type": "number" },
        "precoUnitario": { "type": "number" }
      },
      "required": ["produtoId", "fornecedorId", "data", "quantidade", "precoUnitario"]
    },
    "ContaAPagar": {
      "title": "Conta a Pagar",
      "description": "Representa uma conta a ser paga.",
      "type": "object",
      "properties": {
        "descricao": { "type": "string" },
        "fornecedorId": { "type": "string" },
        "valor": { "type": "number" },
        "dataVencimento": { "type": "string", "format": "date" },
        "estaPaga": { "type": "boolean", "default": false }
      },
      "required": ["descricao", "valor", "dataVencimento", "estaPaga"]
    },
    "Funcionario": {
      "title": "Funcionário",
      "description": "Representa um funcionário.",
      "type": "object",
      "properties": {
        "nome": { "type": "string" },
        "funcao": { "type": "string" }
      },
      "required": ["nome", "funcao"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": {
            "$ref": "#/backend/entities/UserProfile"
          },
          "description": "Stores user profile data."
        }
      },
      {
        "path": "/order_items/{orderItemId}",
        "definition": {
          "entityName": "OrderItem",
          "schema": {
            "$ref": "#/backend/entities/OrderItem"
          },
          "description": "Collection of all order items across all users."
        }
      },
      {
        "path": "/favorite_clients/{clientId}",
        "definition": {
          "entityName": "FavoriteClient",
          "schema": {
            "$ref": "#/backend/entities/FavoriteClient"
          },
          "description": "Collection of all favorite clients across all users."
        }
      },
      {
        "path": "/bomboniere_items/{itemId}",
        "definition": {
          "entityName": "BomboniereItem",
          "schema": {
            "$ref": "#/backend/entities/BomboniereItem"
          },
          "description": "Shared list of bomboniere items."
        }
      },
      {
        "path": "/daily_reports/{reportId}",
        "definition": {
            "entityName": "DailyReport",
            "schema": {
                "$ref": "#/backend/entities/DailyReport"
            },
            "description": "Stores consolidated daily sales reports."
        }
      },
      {
        "path": "/fornecedores/{fornecedorId}",
        "definition": {
          "entityName": "Fornecedor",
          "schema": { "$ref": "#/backend/entities/Fornecedor" }
        }
      },
      {
        "path": "/produtos/{produtoId}",
        "definition": {
          "entityName": "Produto",
          "schema": { "$ref": "#/backend/entities/Produto" }
        }
      },
      {
        "path": "/entradas_mercadorias/{entradaId}",
        "definition": {
          "entityName": "EntradaMercadoria",
          "schema": { "$ref": "#/backend/entities/EntradaMercadoria" }
        }
      },
      {
        "path": "/contas_a_pagar/{contaId}",
        "definition": {
          "entityName": "ContaAPagar",
          "schema": { "$ref": "#/backend/entities/ContaAPagar" }
        }
      },
      {
        "path": "/funcionarios/{funcionarioId}",
        "definition": {
          "entityName": "Funcionario",
          "schema": { "$ref": "#/backend/entities/Funcionario" }
        }
      }
    ]
  }
}
