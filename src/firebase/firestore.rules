
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check ownership
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Rule for the 'users' collection and its subcollections
    match /users/{userId} {
      // Users can only manage their own profile document
      allow read, write: if isOwner(userId);
      
      // Users can manage the 'order_items' subcollection within their own document
      match /order_items/{orderItemId} {
        allow read, write: if isOwner(userId);
      }
    }
    
    // bomboniere_items are public for any authenticated user
    match /bomboniere_items/{itemId} {
      allow read, write: if request.auth != null;
    }

    // daily_reports can be read/written by their owner
    match /daily_reports/{reportId} {
       allow read, write: if request.auth != null && (request.resource.data.userId == request.auth.uid || resource.data.userId == request.auth.uid);
       allow list: if request.auth != null;
    }
    
    // All other admin-related collections are accessible to any authenticated user
    match /fornecedores/{fornecedorId} {
      allow read, write: if request.auth != null;
    }

    match /contas_a_pagar/{contaId} {
       allow read, write: if request.auth != null;
    }
    
    match /entradas_mercadorias/{entradaId} {
        allow read, write: if request.auth != null;
    }
    
    match /funcionarios/{funcionarioId} {
        allow read, write: if request.auth != null;
    }

    match /funcionarios/{funcionarioId}/lancamentos/{lancamentoId} {
        allow read, write: if request.auth != null;
    }

    match /funcionarios/{funcionarioId}/holerites/{holeriteId} {
        allow read, write: if request.auth != null;
    }
  }
}
