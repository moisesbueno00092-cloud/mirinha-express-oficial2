rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Utilizadores só podem aceder e modificar os seus próprios dados.
    match /users/{userId}/{document=**} {
      allow read, write, delete: if request.auth != null && request.auth.uid == userId;
    }

    // Itens da bomboniere podem ser lidos por todos, mas escritos apenas por utilizadores autenticados (a lógica da app restringe a escrita).
    match /bomboniere_items/{itemId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null; // Assumindo que a edição é feita em painel de admin
    }

    // Coleções de administração (qualquer utilizador autenticado pode ler e escrever, assumindo que o acesso é controlado pela UI)
    match /fornecedores/{fornecedorId} {
        allow read, write: if request.auth != null;
    }

    match /contas_a_pagar/{contaId} {
        allow read, write: if request.auth != null;
    }

    match /entradas_mercadorias/{entradaId} {
        allow read, write: if request.auth != null;
    }

    match /funcionarios/{funcionarioId}/{document=**} {
        allow read, write: if request.auth != null;
    }
  }
}
