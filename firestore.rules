
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // This rule allows any user with a valid Firebase auth token to read and write
    // all documents in your Firestore database. It's useful for rapid prototyping,
    // but you should secure your data before going to production.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
