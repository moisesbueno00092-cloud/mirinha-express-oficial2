
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Permite o acesso de leitura e escrita a qualquer utilizador autenticado em qualquer documento.
    // A segurança dos dados é garantida nas consultas da aplicação, que filtram
    // os documentos pelo ID do utilizador (ex: where('userId', '==', user.uid)).
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
