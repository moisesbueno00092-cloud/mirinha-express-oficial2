
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to check if the user is the owner of the user document
    // they are trying to access.
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description
     *   Manages the user's own profile document.
     * @path
     *   /users/{userId}
     */
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      /**
       * @description
       *   Manages a user's order items.
       * @path
       *   /users/{userId}/order_items/{orderItemId}
       */
      match /order_items/{orderItemId} {
        allow read, write: if isOwner(userId);
      }

      /**
       * @description
       *   Manages a user's favorite clients.
       * @path
       *   /users/{userId}/favorite_clients/{clientId}
       */
      match /favorite_clients/{clientId} {
        allow read, write: if isOwner(userId);
      }
    }
    
    /**
     * @description
     *   Manages the shared list of bomboniere items (products).
     *   Allows any authenticated user to read or write, as stock management
     *   is handled collaboratively.
     * @path
     *   /bomboniere_items/{itemId}
     */
    match /bomboniere_items/{itemId} {
        allow read, write: if isSignedIn();
    }
    
    /**
     * @description
     *   Manages saved daily reports.
     *   Any authenticated user can read/write reports.
     * @path
     *   /daily_reports/{reportId}
     */
    match /daily_reports/{reportId} {
      allow read, write: if isSignedIn();
    }
  }
}
