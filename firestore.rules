rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Permite que qualquer utilizador autenticado leia e escreva em qualquer documento.
    // Esta regra é permissiva e deve ser usada para desenvolvimento.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
