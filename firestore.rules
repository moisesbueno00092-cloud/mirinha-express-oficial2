
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to check if the user is the owner of the user document
    // they are trying to access.
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description
     *   Manages user-specific data. A user can only access their own document
     *   and the sub-collections within it. This is a path-based security model.
     * @path
     *   /users/{userId}
     */
    match /users/{userId}/{document=**} {
      // Allow full read and write access if the user is the owner of this path.
      // This single rule securely covers the user's profile document and all
      // documents in all sub-collections (like order_items, favorite_clients, etc.).
      allow read, write: if isOwner(userId);
    }
    
    /**
     * @description
     *   Manages the shared list of bomboniere items (products).
     *   Allows any authenticated user to read or write, as stock management
     *   is handled collaboratively.
     * @path
     *   /bomboniere_items/{itemId}
     */
    match /bomboniere_items/{itemId} {
        allow read, write: if isSignedIn();
    }
    
    /**
     * @description
     *   Manages saved daily reports.
     *   Any authenticated user can read/write reports.
     * @path
     *   /daily_reports/{reportId}
     */
    match /daily_reports/{reportId} {
      allow read, write: if isSignedIn();
    }
  }
}
