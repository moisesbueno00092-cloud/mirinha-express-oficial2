rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    match /order_items/{docId} {
      allow read, write: if true;
    }

    match /daily_reports/{docId} {
      allow read, write: if true;
    }

    match /client_accounts/{clientAccountId} {
      allow read, write, delete, list: if true;
    }

    match /bomboniere_items/{docId} {
      allow read, write: if true;
    }

    match /favorite_clients/{docId} {
      allow read, write: if true;
    }
  }
}
