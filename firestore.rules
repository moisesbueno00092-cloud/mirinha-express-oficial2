
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Function to check if a user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to check if the user is the owner of a document
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /**
     * @description
     *   Manages the user's own profile document.
     *   Only the owner of the document can read or write to it.
     */
    match /users/{userId} {
      allow read, write: if isSignedIn() && isOwner(userId);
    }

    /**
     * @description
     *   Generic rule for user-owned data.
     *   - Users can create documents if they set the userId to their own UID.
     *   - Users can read, update, or delete documents they own.
     *   This rule applies to collections where documents have a 'userId' field.
     */
    match /order_items/{orderItemId} {
       allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
       allow read, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /favorite_clients/{clientId} {
       allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
       allow read, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /daily_reports/{reportId} {
      allow read, write: if isSignedIn();
    }

    match /expenses/{expenseId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /payables/{payableId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /employees/{employeeId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      // Salary advances for a specific employee.
      match /advances/{advanceId} {
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow read, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      }
    }
    
    // Shared, public data that any authenticated user can manage.
    match /bomboniere_items/{itemId} {
        allow read, write: if isSignedIn();
    }
  }
}
