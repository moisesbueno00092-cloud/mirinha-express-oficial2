/**
 * Core Philosophy: This ruleset enforces a public access model. It is designed for a single-user application (like a personal tracker) where the primary goal is to sync data across devices without requiring user login. Any client can read and write data.
 *
 * Data Structure: The data is organized in two flat top-level collections: `order_items` and `daily_reports`.
 *
 * Key Security Decisions:
 * - Public Access: All operations (read, write, delete) on any data are permitted. This is a deliberate choice for a single-user app model where ease of access is prioritized over security.
 *
 * Denormalization for Authorization: This model is simple and does not currently require denormalization.
 *
 * Structural Segregation: Not applicable, as all data resides in collections with a uniform public security posture.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows public read and write access to order items.
     * @path        /order_items/{orderItemId}
     * @allow       (read, write) Any client can create, read, update, and delete order items.
     * @principle   Provides open access for a simple, single-user application.
     */
    match /order_items/{orderItemId} {
      allow read, write: if true;
    }
    
    /**
     * @description Allows public read and write access to daily reports.
     * @path        /daily_reports/{reportId}
     * @allow       (read, write) Any client can create, read, and update daily reports.
     * @principle   Provides open access for storing historical data.
     */
    match /daily_reports/{reportId} {
      allow read, write: if true;
    }
  }
}

    