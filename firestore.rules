
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }
    
    // Global rule: allow read/write if the user is authenticated.
    // Security is enforced by client-side queries with where('userId', '==', user.uid)
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
