
rules_version = '2';

/**
 * # Firestore Security Rules
 *
 * ## Core Philosophy
 * This ruleset enforces a user-ownership model where users can only access
 * documents that contain their `userId`. This is a data-based security model.
 *
 * ## Data Structure
 * - Each document in a protected collection (e.g., `order_items`) must have a
 *   `userId` field matching the UID of the authenticated user.
 * - Shared data, like `bomboniere_items`, is readable by any authenticated user.
 */
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function for reusable logic
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to check if the user is the owner based on a `userId` field
    // on an *existing* document.
    function isDataOwner() {
      return isSignedIn() && request.auth.uid == resource.data.userId;
    }
    
    // Helper function for create operations, checking incoming data.
    function isCreatingOwner() {
      return isSignedIn() && request.auth.uid == request.resource.data.userId;
    }

    /**
     * @description
     *   Manages user order items. Access is granted if the document's `userId`
     *   field matches the authenticated user's UID. This allows for secure
     *   `list` queries using a `where("userId", "==", request.auth.uid)` clause.
     * @path
     *   /order_items/{orderItemId}
     */
    match /order_items/{orderItemId} {
      // Allow LIST if the query is securely filtered by the user's ID.
      // Allow GET if the user is the direct owner of the document.
      allow read: if isSignedIn() && (
                    (request.query.limit > 0 || request.query.offset > 0) ? request.query.where.get("userId", "") == request.auth.uid : resource.data.userId == request.auth.uid
                  );
      allow create: if isCreatingOwner();
      allow update, delete: if isDataOwner();
    }
    
    /**
     * @description
     *   Manages user favorite clients. Access is granted if the document's `userId`
     *   field matches the authenticated user's UID.
     * @path
     *   /favorite_clients/{clientId}
     */
    match /favorite_clients/{clientId} {
      // Allow LIST if the query is securely filtered by the user's ID.
      // Allow GET if the user is the direct owner of the document.
      allow read: if isSignedIn() && (
                    (request.query.limit > 0 || request.query.offset > 0) ? request.query.where.get("userId", "") == request.auth.uid : resource.data.userId == request.auth.uid
                  );
      allow create: if isCreatingOwner();
      allow update, delete: if isDataOwner();
    }

    /**
     * @description
     *   Manages the shared list of bomboniere items (products).
     *   Allows any authenticated user to read or write, as stock management
     *   is handled collaboratively.
     * @path
     *   /bomboniere_items/{itemId}
     */
    match /bomboniere_items/{itemId} {
        allow read, write: if isSignedIn();
    }
    
    /**
     * @description
     *   Manages saved daily reports.
     *   Any authenticated user can read/write reports.
     * @path
     *   /daily_reports/{reportId}
     */
    match /daily_reports/{reportId} {
      allow read, write: if isSignedIn();
    }
  }
}
