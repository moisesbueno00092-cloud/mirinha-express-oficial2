rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      // Permite que o utilizador aceda ao seu próprio documento de perfil.
      allow read, write: if request.auth.uid == userId;

      // Permite que o utilizador leia e escreva na sua própria subcoleção de pedidos.
      // A permissão 'read' aqui inclui 'get' e 'list'.
      match /order_items/{orderItemId} {
        allow read, write: if request.auth.uid == userId;
      }
    }

    // Regras explícitas para as outras coleções, permitindo acesso a qualquer usuário autenticado
    match /bomboniere_items/{itemId} {
      allow read, write: if request.auth != null;
    }
    match /daily_reports/{reportId} {
      allow read, write: if request.auth != null;
    }
    match /fornecedores/{fornecedorId} {
      allow read, write: if request.auth != null;
    }
    match /contas_a_pagar/{contaId} {
      allow read, write: if request.auth != null;
    }
    match /entradas_mercadorias/{entradaId} {
      allow read, write: if request.auth != null;
    }
    match /funcionarios/{funcionarioId}/{document=**} {
        allow read, write: if request.auth != null;
    }
  }
}
