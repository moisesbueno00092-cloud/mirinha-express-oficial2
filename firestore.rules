
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read, create, update, delete: if isOwner(userId);
    }
    
    match /order_items/{orderItemId} {
      allow read, create, update, delete: if isOwner(request.resource.data.userId) || isOwner(resource.data.userId);
    }

    match /favorite_clients/{clientId} {
       allow read, create, update, delete: if isOwner(request.resource.data.userId) || isOwner(resource.data.userId);
    }

    match /bomboniere_items/{itemId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null; 
    }
    
    match /daily_reports/{reportId} {
       allow read, write: if request.auth != null;
    }

    match /expenses/{expenseId} {
      allow read, create, update, delete: if isOwner(request.resource.data.userId) || isOwner(resource.data.userId);
    }
    
    match /employees/{employeeId} {
      allow read, create, update, delete: if isOwner(request.resource.data.userId) || isOwner(resource.data.userId);
    }

    match /employees/{employeeId}/advances/{advanceId} {
       allow read, create, update, delete: if isOwner(resource.data.userId) || isOwner(request.resource.data.userId);
    }
  }
}

    