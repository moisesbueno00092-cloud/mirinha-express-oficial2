
/**
 * Core Philosophy: This ruleset enforces a public access model. It is designed for a single-user application (like a personal tracker) where the primary goal is to sync data across devices without requiring user login. Any client can read and write data.
 *
 * Data Structure: The data is organized in five flat top-level collections: `order_items`, `daily_reports`, `client_accounts`, `bomboniere_items`, and `favorite_clients`.
 *
 * Key Security Decisions:
 * - Public Access: All operations (read, write, delete) on any data are permitted. This is a deliberate choice for a single-user app model where ease of access is prioritized over security.
 *
 * Denormalization for Authorization: This model is simple and does not currently require denormalization.
 *
 * Structural Segregation: Not applicable, as all data resides in collections with a uniform public security posture.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows public read and write access to order items.
     * @path        /order_items/{orderItemId}
     * @allow       (read, write) Any client can create, read, update, and delete order items.
     * @principle   Provides open access for a simple, single-user application.
     */
    match /order_items/{orderItemId} {
      allow read, write: if true;
    }
    
    /**
     * @description Allows public read and write access to daily reports.
     * @path        /daily_reports/{reportId}
     * @allow       (read, write) Any client can create, read, and update daily reports.
     * @principle   Provides open access for storing historical data.
     */
    match /daily_reports/{reportId} {
      allow read, write: if true;
    }

    /**
     * @description Allows public read and write access to individual client account entries.
     * @path        /client_accounts/{clientAccountId}
     * @allow       (read, write) Any client can create, read, update, and delete entries.
     * @principle   Provides open access for a simple, single-user application.
     */
    match /client_accounts/{clientAccountId} {
        allow read, write: if true;
    }

    /**
     * @description Allows listing of the entire client_accounts collection.
     * @path        /client_accounts
     * @allow       (list) Any client can list all client account entries for display.
     * @principle   Required for the main accounts page to function correctly.
     */
    match /client_accounts {
        allow list: if true;
    }

    /**
     * @description Allows public read and write access to bomboniere items.
     * @path        /bomboniere_items/{bomboniereItemId}
     * @allow       (read, write) Any client can create, read, update, and delete bomboniere items.
     * @principle   Provides open access for a simple, single-user application to synchronize data.
     */
    match /bomboniere_items/{bomboniereItemId} {
        allow read, write: if true;
    }
    
    /**
     * @description Allows public read and write access to favorite clients.
     * @path        /favorite_clients/{favoriteClientId}
     * @allow       (read, write) Any client can create, read, update, and delete favorite clients.
     * @principle   Provides open access for a simple, single-user application to synchronize data.
     */
    match /favorite_clients/{favoriteClientId} {
        allow read, write: if true;
    }
  }
}
