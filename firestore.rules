
rules_version = '2';

/**
 * # Firestore Security Rules
 *
 * ## Core Philosophy
 * This ruleset enforces a strict user-ownership model for user-specific data,
 * while allowing public read access for shared application data like products.
 * The default security posture is to deny all access unless explicitly granted.
 *
 * ## Data Structure
 * - User-specific data is stored under `/users/{userId}/...`.
 * - Shared data, like `bomboniere_items`, is stored at the root.
 *
 * ## Key Security Decisions
 * - **User Data Ownership:** All create, read, update, and delete operations
 *   on user data are restricted to the owner.
 * - **Public Read for Shared Data:** Collections like `bomboniere_items` are
 *   readable by any authenticated user to populate the application UI.
 * - **Write Restrictions on Shared Data:** Writing to shared collections is
 *   denied by default and should be governed by more specific rules if needed
 *   (e.g., admin roles).
 */
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function for reusable logic
    function isSignedIn() {
      return request.auth != null;
    }

    // Checks if the requesting user is the owner of the document based on the path.
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description
     *   Manages user-specific data. This rule block secures all sub-collections
     *   under a user's document, such as order_items and favorite_clients.
     * @path
     *   /users/{userId}
     */
    match /users/{userId} {
      /**
       * @description
       *   Grants full create, read, update, and delete permissions exclusively
       *   to the user who owns the data. This rule explicitly allows `list`
       *   operations on the collection.
       * @path
       *   /users/{userId}/order_items/{orderItemId}
       */
      match /order_items/{orderItemId} {
        allow list, get: if isOwner(userId);
        allow create, update, delete: if isOwner(userId);
      }

      /**
       * @description
       *   Manages the list of favorite clients saved by a user.
       *   Grants full permissions to the user who owns the data.
       * @path
       *   /users/{userId}/favorite_clients/{clientId}
       */
      match /favorite_clients/{clientId} {
        allow list, get: if isOwner(userId);
        allow create, update, delete: if isOwner(userId);
      }
    }
    
    /**
     * @description
     *   Manages the shared list of bomboniere items (products).
     *   Allows any authenticated user to read the list of items for display
     *   in the application. Write access is also allowed for authenticated
     *   users to enable stock updates from the main app and stock page.
     * @path
     *   /bomboniere_items/{itemId}
     * @allow
     *   Any authenticated user can read or write bomboniere items.
     */
    match /bomboniere_items/{itemId} {
        allow read, write: if isSignedIn();
    }
    
    /**
     * @description
     *   Manages saved daily reports.
     *   This rule is currently open for any authenticated user. For a multi-user
     *   system, this should be nested under the user's private data path.
     * @path
     *   /daily_reports/{reportId}
     */
    match /daily_reports/{reportId} {
      allow read, write: if isSignedIn();
    }
  }
}
