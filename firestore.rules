
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /**
     * @description
     *   Manages the user's own profile document.
     *   Only the owner of the document can read or write to it.
     * @path
     *   /users/{userId}
     */
    match /users/{userId} {
      allow read, write: if isSignedIn() && isOwner(userId);
    }

    /**
     * @description
     *   Manages order items. Users can only access their own items.
     *   - List: Allowed only if the query filters by the user's own userId.
     *   - Get: Allowed if the document's userId matches the requesting user.
     *   - Write: Allowed if the new/updated data's userId matches the requesting user.
     * @path
     *   /order_items/{orderItemId}
     */
    match /order_items/{orderItemId} {
       allow read: if isSignedIn() && (
         (request.method == 'list' && request.query.where.get('userId', '') == request.auth.uid) ||
         (request.method == 'get' && resource.data.userId == request.auth.uid)
       );
       allow write: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }
    
    /**
     * @description
     *   Manages favorite clients. Users can only access their own saved clients.
     *   - List: Allowed only if the query filters by the user's own userId.
     *   - Get: Allowed if the document's userId matches the requesting user.
     *   - Write: Allowed if the new/updated data's userId matches the requesting user.
     * @path
     *   /favorite_clients/{clientId}
     */
    match /favorite_clients/{clientId} {
       allow read: if isSignedIn() && (
         (request.method == 'list' && request.query.where.get('userId', '') == request.auth.uid) ||
         (request.method == 'get' && resource.data.userId == request.auth.uid)
       );
       allow write: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    /**
     * @description
     *   Manages the shared list of bomboniere items (products).
     *   Allows any authenticated user to read or write, as stock management
     *   is handled collaboratively.
     * @path
     *   /bomboniere_items/{itemId}
     */
    match /bomboniere_items/{itemId} {
        allow read, write: if isSignedIn();
    }
    
    /**
     * @description
     *   Manages saved daily reports.
     *   Any authenticated user can read/write reports.
     * @path
     *   /daily_reports/{reportId}
     */
    match /daily_reports/{reportId} {
      allow read, write: if isSignedIn();
    }
  }
}
