{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "type": "object",
      "description": "Represents a user's profile information.",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        }
      },
      "required": ["email"]
    },
    "OrderItem": {
      "title": "Order Item",
      "type": "object",
      "description": "Represents an individual item ordered at the restaurant.",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the item ordered."
        },
        "price": {
          "type": "number",
          "description": "The price of the item."
        },
        "group": {
          "type": "string",
          "description": "The group the item belongs to."
        },
        "quantity": {
          "type": "number",
          "description": "The quantity of the item ordered."
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "The date and time the item was ordered."
        },
        "total": {
          "type": "number"
        }
      },
      "required": ["name", "price", "group", "quantity", "timestamp", "total"]
    },
    "FavoriteClient": {
      "title": "Favorite Client",
      "type": "object",
      "description": "Represents a favorite client with a saved command.",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the favorite client."
        },
        "command": {
          "type": "string",
          "description": "The saved command for the client's usual order."
        }
      },
      "required": ["name", "command"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": {
            "$ref": "#/backend/entities/UserProfile"
          },
          "description": "Stores user profile data.",
          "params": [
            {
              "name": "userId",
              "description": "The unique identifier of the user."
            }
          ]
        }
      },
      {
        "path": "/users/{userId}/order_items/{orderItemId}",
        "definition": {
          "entityName": "OrderItem",
          "schema": {
            "$ref": "#/backend/entities/OrderItem"
          },
          "description": "Sub-collection for a user's order items.",
          "params": [
            {
              "name": "userId",
              "description": "The user's ID."
            },
            {
              "name": "orderItemId",
              "description": "The unique identifier of the order item."
            }
          ]
        }
      },
      {
        "path": "/users/{userId}/favorite_clients/{clientId}",
        "definition": {
          "entityName": "FavoriteClient",
          "schema": {
            "$ref": "#/backend/entities/FavoriteClient"
          },
          "description": "Sub-collection for a user's favorite clients.",
          "params": [
            {
              "name": "userId",
              "description": "The user's ID."
            },
            {
              "name": "clientId",
              "description": "The unique identifier of the favorite client."
            }
          ]
        }
      },
      {
        "path": "/bomboniere_items/{itemId}",
        "definition": {
          "entityName": "BomboniereItem",
          "schema": {
            "$ref": "#/backend/entities/BomboniereItem"
          },
          "description": "Shared list of bomboniere items.",
          "params": [
             {
              "name": "itemId",
              "description": "The unique identifier of the bomboniere item."
            }
          ]
        }
      },
       {
        "path": "/daily_reports/{reportId}",
        "definition": {
          "entityName": "DailyReport",
          "schema": {
            "$ref": "#/backend/entities/DailyReport"
          },
          "description": "Daily sales reports.",
          "params": [
            {
              "name": "reportId",
              "description": "The unique identifier of the daily report."
            }
          ]
        }
      }
    ]
  }
}